# -----------------------------
# Core App / Auth
# -----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------
# Admin / Super Admin Access
# -----------------------------
# Legacy single-value admin keys (still supported)
ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Preferred comma-separated admin list keys
ADMIN_EMAILS=admin@example.com,another-admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com,another-admin@example.com

# Super admin keys (for super-admin-only controls)
SUPER_ADMIN_EMAIL=superadmin@example.com
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_EMAILS=superadmin@example.com
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=superadmin@example.com

# -----------------------------
# SMTP (Invite Friend emails)
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=E-Learning Platform

# -----------------------------
# Code Execution (DSA submit)
# -----------------------------
ONECOMPILER_RAPIDAPI_HOST=onecompiler-apis.p.rapidapi.com
ONECOMPILER_RAPIDAPI_KEY=your_rapidapi_key

# -----------------------------
# AI Providers
# -----------------------------
# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Mistral (used by validate-code route)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions

# BYOK encryption secret (server-side only)
# Use a long random hex string (64+ chars recommended)
USER_API_KEY_ENCRYPTION_SECRET=replace_with_long_random_hex_secret
